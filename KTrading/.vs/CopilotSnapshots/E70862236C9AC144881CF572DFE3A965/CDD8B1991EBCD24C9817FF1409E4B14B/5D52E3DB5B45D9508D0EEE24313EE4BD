@page "{id:guid}"
@model KTrading.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-trash"></i> Delete Product</h3>
    </div>
    <div class="card-body">
        <h5>@Model.Product?.Name</h5>
        <p>SKU: @Model.Product?.SKU</p>
        <p>Unit: @Model.Product?.Unit</p>
        <p>Price: @Model.Product?.Price.ToString("N2")</p>

        <form method="post">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </form>
    </div>
</div>