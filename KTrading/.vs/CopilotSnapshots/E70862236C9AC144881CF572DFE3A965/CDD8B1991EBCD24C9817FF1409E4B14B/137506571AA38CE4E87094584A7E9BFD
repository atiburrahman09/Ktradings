@page "{id:guid}"
@model KTrading.Pages.SalesOrders.DetailsModel
@{
    ViewData["Title"] = "Sales Order Details";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-invoice-dollar"></i> Sales Order Details</h3>
    </div>
    <div class="card-body">
        <h4>Order #: @Model.Order?.OrderNumber</h4>
        <p>Customer: @Model.Order?.CustomerId</p>
        <p>Date: @Model.Order?.OrderDate.ToString("yyyy-MM-dd")</p>
        <p>Total: @Model.Order?.Total.ToString("N2")</p>

        <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>