@page
@model KTrading.Pages.SalesOrders.CreateModel
@{
    ViewData["Title"] = "Create Sales Order";
}

<h2>Create Sales Order</h2>

<form method="post">
    <div class="mb-3">
        <label asp-for="SalesOrder.CustomerId" class="form-label">Customer</label>
        <select asp-for="SalesOrder.CustomerId" asp-items="Model.CustomerList" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="SalesOrder.OrderDate" class="form-label"></label>
        <input asp-for="SalesOrder.OrderDate" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}