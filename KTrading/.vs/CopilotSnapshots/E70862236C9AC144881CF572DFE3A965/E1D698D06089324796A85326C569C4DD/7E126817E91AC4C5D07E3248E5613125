using Microsoft.AspNetCore.Identity;
using Microsoft.EntityFrameworkCore;
using KTrading.Models;

namespace KTrading.Data
{
    public static class SeedData
    {
        public static async Task InitializeAsync(IServiceProvider services)
        {
            using var scope = services.CreateScope();
            var provider = scope.ServiceProvider;
            var context = provider.GetRequiredService<ApplicationDbContext>();
            var userManager = provider.GetRequiredService<UserManager<IdentityUser>>();
            var roleManager = provider.GetRequiredService<RoleManager<IdentityRole>>();

            // Try to apply migrations; if migrations are not present (development) fall back to EnsureCreated
            try
            {
                await context.Database.MigrateAsync();
            }
            catch
            {
                try
                {
                    await context.Database.EnsureCreatedAsync();
                }
                catch
                {
                    // ignore
                }
            }

            // Seed roles
            var roles = new[] { "Admin", "Sales", "Warehouse", "Manager" };
            foreach (var role in roles)
            {
                if (!await roleManager.RoleExistsAsync(role))
                {
                    await roleManager.CreateAsync(new IdentityRole(role));
                }
            }

            // Seed admin user
            var adminEmail = "admin@ktrading.local";
            var admin = await userManager.FindByEmailAsync(adminEmail);
            var desiredPassword = "Admin123!";

            if (admin == null)
            {
                admin = new IdentityUser
                {
                    UserName = adminEmail,
                    Email = adminEmail,
                    EmailConfirmed = true
                };
                var result = await userManager.CreateAsync(admin, desiredPassword);
                if (result.Succeeded)
                {
                    await userManager.AddToRoleAsync(admin, "Admin");
                }
            }
            else
            {
                // Ensure username equals email so default Identity login uses email
                if (!string.Equals(admin.UserName, adminEmail, StringComparison.OrdinalIgnoreCase))
                {
                    await userManager.SetUserNameAsync(admin, adminEmail);
                }
                if (!await userManager.IsInRoleAsync(admin, "Admin"))
                {
                    await userManager.AddToRoleAsync(admin, "Admin");
                }
                if (!admin.EmailConfirmed)
                {
                    admin.EmailConfirmed = true;
                    await userManager.UpdateAsync(admin);
                }

                // Ensure password matches desired password; reset if necessary
                var hasPassword = await userManager.HasPasswordAsync(admin);
                var passwordValid = await userManager.CheckPasswordAsync(admin, desiredPassword);
                if (!passwordValid)
                {
                    if (hasPassword)
                    {
                        var removeResult = await userManager.RemovePasswordAsync(admin);
                        // Log remove failures optionally
                    }
                    var addResult = await userManager.AddPasswordAsync(admin, desiredPassword);
                    if (!addResult.Succeeded)
                    {
                        var logger = provider.GetService<ILoggerFactory>()?.CreateLogger("SeedData");
                        if (logger != null)
                        {
                            foreach (var err in addResult.Errors)
                                logger.LogError("Failed to set admin password: {Code} - {Desc}", err.Code, err.Description);
                        }
                    }
                }
            }

            // Seed products
            if (!await context.Products.AnyAsync())
            {
                var products = new List<Product>
                {
                    new Product { Id = Guid.NewGuid(), SKU = "P-1001", Name = "Box of Nails", Unit = "Box", Price = 12.50m, Cost = 8.00m, VATPercent = 5m, IsActive = true, CreatedAt = DateTimeOffset.UtcNow },
                    new Product { Id = Guid.NewGuid(), SKU = "P-1002", Name = "Hammer", Unit = "Each", Price = 18.00m, Cost = 10.00m, VATPercent = 5m, IsActive = true, CreatedAt = DateTimeOffset.UtcNow },
                    new Product { Id = Guid.NewGuid(), SKU = "P-1003", Name = "Screwdriver", Unit = "Each", Price = 9.75m, Cost = 5.00m, VATPercent = 5m, IsActive = true, CreatedAt = DateTimeOffset.UtcNow },
                    new Product { Id = Guid.NewGuid(), SKU = "P-1004", Name = "Fresh Noodles - 30g", Unit = "Ctn", Price = 7.85m, Cost = 4.50m, VATPercent = 5m, IsActive = true, CreatedAt = DateTimeOffset.UtcNow },
                    new Product { Id = Guid.NewGuid(), SKU = "P-1005", Name = "Fresh Noodles - 140g", Unit = "Ctn", Price = 40.00m, Cost = 25.00m, VATPercent = 5m, IsActive = true, CreatedAt = DateTimeOffset.UtcNow },
                };
                await context.Products.AddRangeAsync(products);
                await context.SaveChangesAsync();
            }

            // Seed customers
            if (!await context.Customers.AnyAsync())
            {
                var customers = new List<Customer>
                {
                    new Customer { Id = Guid.NewGuid(), Name = "Default Customer", Code = "CUST-001", ContactName = "John Doe", Phone = "555-0100", CreatedAt = DateTimeOffset.UtcNow },
                    new Customer { Id = Guid.NewGuid(), Name = "ACME Supplies", Code = "CUST-002", ContactName = "Alice", Phone = "555-0101", CreatedAt = DateTimeOffset.UtcNow },
                    new Customer { Id = Guid.NewGuid(), Name = "Retailer One", Code = "CUST-003", ContactName = "Bob", Phone = "555-0102", CreatedAt = DateTimeOffset.UtcNow },
                };
                await context.Customers.AddRangeAsync(customers);
                await context.SaveChangesAsync();
            }

            // Seed stocks and movements
            if (!await context.Stocks.AnyAsync())
            {
                var prods = await context.Products.ToListAsync();
                var customers = await context.Customers.ToListAsync();
                var stocks = new List<Stock>();
                var movements = new List<StockMovement>();

                foreach (var p in prods)
                {
                    var s = new Stock { Id = Guid.NewGuid(), ProductId = p.Id, Quantity = 100, UpdatedAt = DateTimeOffset.UtcNow };
                    stocks.Add(s);

                    // few movements
                    movements.Add(new StockMovement { Id = Guid.NewGuid(), ProductId = p.Id, Quantity = 100, MovementType = "IN", ReferenceId = Guid.Empty, Note = "Initial stock", CreatedAt = DateTimeOffset.UtcNow.AddDays(-10) });
                    movements.Add(new StockMovement { Id = Guid.NewGuid(), ProductId = p.Id, Quantity = -5, MovementType = "OUT", ReferenceId = Guid.Empty, Note = "Sample sale", CreatedAt = DateTimeOffset.UtcNow.AddDays(-5) });
                    movements.Add(new StockMovement { Id = Guid.NewGuid(), ProductId = p.Id, Quantity = -2, MovementType = "DAMAGE", ReferenceId = Guid.Empty, Note = "Damaged", CreatedAt = DateTimeOffset.UtcNow.AddDays(-2) });
                }

                await context.Stocks.AddRangeAsync(stocks);
                await context.StockMovements.AddRangeAsync(movements);
                await context.SaveChangesAsync();
            }

            // Seed sales orders
            if (!await context.SalesOrders.AnyAsync())
            {
                var prod = await context.Products.FirstOrDefaultAsync();
                var cust = await context.Customers.FirstOrDefaultAsync();
                if (prod != null && cust != null)
                {
                    var order = new SalesOrder { Id = Guid.NewGuid(), OrderNumber = "SO-1001", CustomerId = cust.Id, OrderDate = DateTimeOffset.UtcNow.AddDays(-3), CreatedAt = DateTimeOffset.UtcNow.AddDays(-3), Subtotal = 50m, Total = 50m };
                    var item = new SalesOrderItem { Id = Guid.NewGuid(), SalesOrderId = order.Id, ProductId = prod.Id, Quantity = 2, UnitPrice = prod.Price, LineTotal = 2 * prod.Price };
                    context.SalesOrders.Add(order);
                    context.SalesOrderItems.Add(item);

                    // create corresponding stock movement
                    var sm = new StockMovement { Id = Guid.NewGuid(), ProductId = prod.Id, Quantity = -item.Quantity, MovementType = "OUT", ReferenceId = order.Id, Note = "Sale", CreatedAt = DateTimeOffset.UtcNow.AddDays(-3) };
                    context.StockMovements.Add(sm);

                    var stock = await context.Stocks.FirstOrDefaultAsync(s => s.ProductId == prod.Id);
                    if (stock != null)
                    {
                        stock.Quantity -= item.Quantity;
                        stock.UpdatedAt = DateTimeOffset.UtcNow.AddDays(-3);
                    }

                    await context.SaveChangesAsync();
                }
            }

            // Seed payment methods and statuses
            if (!await context.PaymentMethods.AnyAsync())
            {
                context.PaymentMethods.AddRange(new PaymentMethod { Name = "Cash" }, new PaymentMethod { Name = "BankTransfer" }, new PaymentMethod { Name = "CreditCard" });
                await context.SaveChangesAsync();
            }

            if (!await context.OrderStatuses.AnyAsync())
            {
                context.OrderStatuses.AddRange(new OrderStatus { Id = 1, Name = "Draft" }, new OrderStatus { Id = 2, Name = "Confirmed" }, new OrderStatus { Id = 5, Name = "Completed" });
                await context.SaveChangesAsync();
            }

            // Seed product returns
            if (!await context.ProductReturns.AnyAsync())
            {
                var prod = await context.Products.FirstOrDefaultAsync();
                var cust = await context.Customers.FirstOrDefaultAsync();
                if (prod != null)
                {
                    var r = new ProductReturn { Id = Guid.NewGuid(), ReturnNumber = "R-1001", CustomerId = cust?.Id, Reason = "Customer returned due to defect", Status = "Open", CreatedAt = DateTimeOffset.UtcNow };
                    context.ProductReturns.Add(r);
                    await context.SaveChangesAsync();

                    var item = new ProductReturnItem { Id = Guid.NewGuid(), ProductReturnId = r.Id, ProductId = prod.Id, Quantity = 1, IsDamaged = true, Notes = "Damaged during shipping" };
                    context.ProductReturnItems.Add(item);
                    await context.SaveChangesAsync();
                }
            }
        }
    }
}
