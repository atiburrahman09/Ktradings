@page "{id:guid}"
@model KTrading.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-edit"></i> Edit Product</h3>
    </div>
    <form method="post" class="card-body">
        <input type="hidden" asp-for="Product.Id" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Product.SKU" class="form-label"></label>
                <input asp-for="Product.SKU" class="form-control" />
                <span asp-validation-for="Product.SKU" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Product.Unit" class="form-label"></label>
                <input asp-for="Product.Unit" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Product.Name" class="form-label"></label>
            <input asp-for="Product.Name" class="form-control" />
            <span asp-validation-for="Product.Name" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Product.Price" class="form-label"></label>
                <input asp-for="Product.Price" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Product.Cost" class="form-label"></label>
                <input asp-for="Product.Cost" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Product.VATPercent" class="form-label"></label>
                <input asp-for="Product.VATPercent" class="form-control" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Product.ProductCategoryId" class="form-label">Category</label>
                <select asp-for="Product.ProductCategoryId" asp-items="Model.CategoryList" class="form-select"></select>
            </div>
            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check mb-0">
                    <input asp-for="Product.IsActive" class="form-check-input" />
                    <label asp-for="Product.IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Save</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}