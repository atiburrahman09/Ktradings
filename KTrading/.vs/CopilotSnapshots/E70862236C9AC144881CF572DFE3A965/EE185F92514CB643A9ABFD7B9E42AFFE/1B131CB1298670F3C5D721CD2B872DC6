@page
@model KTrading.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Products</h2>
    <a class="btn btn-primary" asp-page="Create">Create New</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>SKU</th>
            <th>Name</th>
            <th>Unit</th>
            <th class="text-end">Price</th>
            <th>Active</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Products)
    {
        <tr>
            <td>@p.SKU</td>
            <td>@p.Name</td>
            <td>@p.Unit</td>
            <td class="text-end">@p.Price.ToString("N2")</td>
            <td>@(p.IsActive ? "Yes" : "No")</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@p.Id">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@p.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>