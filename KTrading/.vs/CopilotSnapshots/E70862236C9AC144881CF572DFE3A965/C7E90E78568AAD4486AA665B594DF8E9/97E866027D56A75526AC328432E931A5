@page
@model KTrading.Pages.SalesOrders.IndexModel
@{
    ViewData["Title"] = "Sales Orders";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Sales Orders</h2>
    <a class="btn btn-primary" asp-page="Create">Create New</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Order#</th>
            <th>Customer</th>
            <th>Date</th>
            <th class="text-end">Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var o in Model.Orders)
    {
        <tr>
            <td>@o.OrderNumber</td>
            <td>@o.CustomerId</td>
            <td>@o.OrderDate.ToString("yyyy-MM-dd")</td>
            <td class="text-end">@o.Total.ToString("N2")</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@o.Id">View</a>
            </td>
        </tr>
    }
    </tbody>
</table>