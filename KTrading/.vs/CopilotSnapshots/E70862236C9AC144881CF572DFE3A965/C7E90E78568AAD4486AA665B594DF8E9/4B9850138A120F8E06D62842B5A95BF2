@page
@model KTrading.Pages.Stocks.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Inventory</h2>
    <a class="btn btn-primary" asp-page="Index">Refresh</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Product</th>
            <th class="text-end">Quantity</th>
            <th>Last Updated</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var s in Model.Stocks)
    {
        <tr>
            <td>@(Model.ProductMap.ContainsKey(s.ProductId) ? Model.ProductMap[s.ProductId] : s.ProductId.ToString())</td>
            <td class="text-end">@s.Quantity</td>
            <td>@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@s.Id">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>
