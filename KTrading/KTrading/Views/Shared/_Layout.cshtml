<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KTrading</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var userName = User?.Identity?.Name ?? "User";
    string ActiveFor(params string[] prefixes) => prefixes.Any(prefix => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)) ? "active" : string.Empty;
}
<body class="gentelella-shell @(isAuthenticated ? string.Empty : "auth-page")">
    <div class="app-shell">
        <aside class="left_col">
            <a href="@Url.Page("/Index")" class="site_title">
                <i class="fas fa-warehouse"></i>
                <span>KTrading</span>
            </a>

            @if (isAuthenticated)
            {
                <div class="profile">
                    <div class="profile_pic"><i class="fas fa-user"></i></div>
                    <div class="profile_info">
                        <span>Welcome,</span>
                        <strong>@userName</strong>
                    </div>
                </div>

                <nav class="main_menu">
                    <h3>General</h3>
                    <a asp-page="/Index" class="@ActiveFor("/Index")"><i class="fas fa-gauge-high"></i><span>Dashboard</span></a>
                    <a asp-page="/Products/Index" class="@ActiveFor("/Products")"><i class="fas fa-box"></i><span>Products</span></a>
                    <a asp-page="/ProductCategories/Index" class="@ActiveFor("/ProductCategories")"><i class="fas fa-tags"></i><span>Product Categories</span></a>
                    <a asp-page="/Customers/Index" class="@ActiveFor("/Customers")"><i class="fas fa-users"></i><span>Customers</span></a>
                    <a asp-page="/SalesOrders/Index" class="@ActiveFor("/SalesOrders")"><i class="fas fa-file-invoice-dollar"></i><span>Sales Orders</span></a>
                    <a asp-page="/SalesOfficers/Index" class="@ActiveFor("/SalesOfficers")"><i class="fas fa-user-tie"></i><span>Sales Officers</span></a>

                    <h3>Inventory</h3>
                    <a asp-page="/ProductReturns/Index" class="@ActiveFor("/ProductReturns")"><i class="fas fa-undo-alt"></i><span>Product Returns</span></a>
                    <a asp-page="/Stocks/Index" class="@ActiveFor("/Stocks")"><i class="fas fa-warehouse"></i><span>Stock / Inventory</span></a>
                    <a asp-page="/Stocks/Create" class="@ActiveFor("/Stocks/Create")"><i class="fas fa-plus-circle"></i><span>Add Stock</span></a>
                    <a asp-page="/Reports/InventoryValue" class="@ActiveFor("/Reports")"><i class="fas fa-chart-bar"></i><span>Inventory Report</span></a>
                    <a asp-page="/Help/Index" class="@ActiveFor("/Help")"><i class="fas fa-question-circle"></i><span>Help</span></a>
                </nav>
            }
        </aside>

        <main class="right_col">
            <nav class="top_nav">
                <button class="menu_toggle" type="button" aria-label="Toggle navigation">
                    <i class="fas fa-bars"></i>
                </button>
                <a href="@Url.Page("/Index")" class="top_nav_title">Dashboard</a>

                <div class="top_nav_user">
                    @if (isAuthenticated)
                    {
                        <span><i class="fas fa-user-circle"></i> @userName</span>
                        <form asp-page="/Account/Logout" method="post" id="logoutForm">
                            <button type="submit" class="btn btn-link nav-link"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link" asp-page="/Account/Login"><i class="fas fa-sign-in-alt"></i> Login</a>
                    }
                </div>
            </nav>

            <div class="page-title">
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>KTrading distribution management</p>
                </div>
            </div>

            <section class="content">
                @RenderBody()
            </section>

            <footer class="footer">
                <strong>&copy; 2026 KTrading</strong>
                <span>Gentelella themed admin</span>
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
