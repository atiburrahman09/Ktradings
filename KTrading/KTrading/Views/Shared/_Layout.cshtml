<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KTrading</title>
    <link rel="stylesheet" href="~/lib/adminlte/adminlte.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="@Url.Page("/Index")" class="nav-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
                </li>
            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fas fa-user"></i> Hello @User.Identity.Name</a>
                    </li>
                    <li class="nav-item">
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" method="post" id="logoutForm">
                            <button type="submit" class="btn btn-link nav-link"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                }
            </ul>
        </nav>
        <!-- /.navbar -->

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Page("/Index")" class="brand-link">
                <span class="brand-text font-weight-light"><i class="fas fa-warehouse"></i> KTrading</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar user panel (optional) -->
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                        <div class="info">
                            <a href="#" class="d-block"><i class="fas fa-user-circle"></i> @User.Identity.Name</a>
                        </div>
                    </div>
                }

                <!-- Sidebar Menu -->
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <nav class="mt-2">
                        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                            <li class="nav-item"><a asp-page="/Products/Index" class="nav-link"><i class="nav-icon fas fa-box"></i><p>Products</p></a></li>
                            <li class="nav-item"><a asp-page="/ProductCategories/Index" class="nav-link"><i class="nav-icon fas fa-tags"></i><p>Product Categories</p></a></li>
                            <li class="nav-item"><a asp-page="/Customers/Index" class="nav-link"><i class="nav-icon fas fa-users"></i><p>Customers</p></a></li>
                            <li class="nav-item"><a asp-page="/SalesOrders/Index" class="nav-link"><i class="nav-icon fas fa-file-invoice-dollar"></i><p>Sales Orders</p></a></li>
                            <li class="nav-item"><a asp-page="/SalesOfficers/Index" class="nav-link"><i class="nav-icon fas fa-user-tie"></i><p>Sales Officers</p></a></li>
                            <li class="nav-item"><a asp-page="/ProductReturns/Index" class="nav-link"><i class="nav-icon fas fa-undo-alt"></i><p>Product Returns</p></a></li>
                            <li class="nav-item"><a asp-page="/Stocks/Index" class="nav-link"><i class="nav-icon fas fa-warehouse"></i><p>Inventory</p></a></li>
                            <li class="nav-item"><a asp-page="/Reports/InventoryValue" class="nav-link"><i class="nav-icon fas fa-chart-bar"></i><p>Inventory Report</p></a></li>
                            <li class="nav-item"><a asp-page="/Help/Index" class="nav-link"><i class="nav-icon fas fa-question-circle"></i><p>Help</p></a></li>
                        </ul>
                    </nav>
                }
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1 class="m-0">@ViewData["Title"]</h1>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->

        <footer class="main-footer">
            <div class="float-right d-none d-sm-inline">KTrading</div>
            <strong>&copy; 2026 KTrading</strong>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/adminlte/adminlte.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
