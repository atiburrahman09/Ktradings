@page
@model KTrading.Pages.Stocks.CreateModel
@{
    ViewData["Title"] = "Add Stock";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-plus-circle"></i> Add Stock / Product In</h3>
    </div>
    <form method="post" class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.ProductId" class="form-label">Product</label>
            <select asp-for="Input.ProductId" asp-items="Model.ProductList" class="form-select">
                <option value="">Select product</option>
            </select>
            <span asp-validation-for="Input.ProductId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Quantity" class="form-label">Quantity In</label>
            <input asp-for="Input.Quantity" class="form-control" />
            <span asp-validation-for="Input.Quantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Note" class="form-label">Note</label>
            <textarea asp-for="Input.Note" class="form-control" rows="3"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Add Stock</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
