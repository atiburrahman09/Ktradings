@page
@model KTrading.Pages.Stocks.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Stock / Inventory</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-success" asp-page="Create"><i class="fas fa-plus-circle"></i> Add Stock</a>
            <a class="btn btn-secondary" asp-page="Index">Refresh</a>
        </div>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4">
                <input asp-for="SearchTerm" class="form-control" placeholder="Search product, SKU, or description" />
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i> Search</button>
                <a asp-page="Index" class="btn btn-outline-secondary"><i class="fas fa-times"></i> Clear</a>
            </div>
        </form>

        <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>Product</th>
                    <th class="text-end">Quantity</th>
                    <th>Last Updated</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
            @foreach(var s in Model.Stocks)
            {
                <tr>
                    <td>@(Model.ProductMap.ContainsKey(s.ProductId) ? Model.ProductMap[s.ProductId] : s.ProductId.ToString())</td>
                    <td class="text-end">@s.Quantity</td>
                    <td>@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@s.Id"><i class="fas fa-eye"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
        <partial name="_Pagination" model="Model.Pager" />
    </div>
</div>
