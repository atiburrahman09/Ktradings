@page "{id:guid}"
@model KTrading.Pages.Stocks.DetailsModel
@{
    ViewData["Title"] = "Stock Details";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-warehouse"></i> Stock Details</h3>
    </div>
    <div class="card-body">
        <h4>Product: @Model.ProductName</h4>
        <p>Quantity: @Model.Stock.Quantity</p>
        <p>Updated: @Model.Stock.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</p>
    </div>

    <div class="card-footer">
        <h5 class="mb-2">Recent Movements</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th class="text-end">Quantity</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                @foreach(var m in Model.Movements)
                {
                    <tr>
                        <td>@m.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@m.MovementType</td>
                        <td class="text-end">@m.Quantity</td>
                        <td>@m.Note</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>
