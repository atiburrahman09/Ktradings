@page
@model KTrading.Pages.ProductCategories.IndexModel
@{
    ViewData["Title"] = "Product Categories";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Product Categories</h3>
        <a class="btn btn-primary" asp-page="Create">Create New</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-hover table-bordered">
            <thead class="thead-light">
                <tr>
                    <th>Name</th>
                    <th class="text-end">Products</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.ProductCategories)
            {
                <tr>
                    <td>@c.Name</td>
                    <td class="text-end">@(c.Products?.Count ?? 0)</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@c.Id"><i class="fas fa-edit"></i></a>
                        <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@c.Id"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <partial name="_Pagination" model="Model.Pager" />
    </div>
</div>

