@page
@model KTrading.Pages.ProductCategories.CreateModel
@{
    ViewData["Title"] = "Create Product Category";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-folder-plus"></i> Create Product Category</h3>
    </div>
    <form method="post" class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ProductCategory.Name" class="form-label"></label>
            <input asp-for="ProductCategory.Name" class="form-control" />
            <span asp-validation-for="ProductCategory.Name" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Create</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

