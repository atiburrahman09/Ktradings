@page "{id:guid}"
@model KTrading.Pages.Customers.DeleteModel
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-trash"></i> Delete Customer</h3>
    </div>
    <div class="card-body">
        <h5>@Model.Customer?.Name</h5>
        <p>Code: @Model.Customer?.Code</p>
        <p>Contact: @Model.Customer?.ContactName</p>

        <form method="post">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </form>
    </div>
</div>