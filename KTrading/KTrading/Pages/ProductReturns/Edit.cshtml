@page "{id:guid}"
@model KTrading.Pages.ProductReturns.EditModel
@{
    ViewData["Title"] = "Edit Product Return";
}

@functions {
    private string CategoryValue(Guid? categoryId)
    {
        return categoryId?.ToString() ?? string.Empty;
    }
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-edit"></i> Edit Product Return</h3>
    </div>
    <form method="post" class="card-body">
        <input type="hidden" asp-for="Return.Id" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="Return.ReturnNumber" class="form-label"></label>
                <input asp-for="Return.ReturnNumber" class="form-control" readonly="@(Model.Return.Status == "Processed" ? "readonly" : null)" />
            </div>
            <div class="col-md-4">
                <label asp-for="Return.SalesOrderId" class="form-label">Sales Order</label>
                <select asp-for="Return.SalesOrderId" asp-items="Model.SalesOrders" class="form-select" id="salesOrderSelect" disabled="@(Model.Return.Status == "Processed" ? "disabled" : null)">
                    <option value="">-- select sales order --</option>
                </select>
                @if (Model.Return.Status == "Processed")
                {
                    <input type="hidden" asp-for="Return.SalesOrderId" />
                }
                <span asp-validation-for="Return.SalesOrderId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Customer</label>
                <input class="form-control" value="@(Model.CustomerName ?? "-")" readonly />
            </div>
        </div>

        @if (Model.SelectedSalesOrder is not null)
        {
            <div class="mb-3">
                <div class="alert alert-info mb-0">
                    Return is based on sales order <strong>@Model.SelectedSalesOrder.OrderNumber</strong>.
                    Current return quantities are included in the editable maximum.
                </div>
            </div>

            <h5>Sold Items</h5>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Sold</th>
                            <th class="text-end">Already Returned</th>
                            <th class="text-end">Available</th>
                            <th style="width:170px">Return Quantity</th>
                            <th style="width:170px">Damage Quantity</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.ReturnLines.Count; i++)
                    {
                        var line = Model.ReturnLines[i];
                        var disabled = Model.Return.Status == "Processed";
                        <tr>
                            <td>
                                @line.ProductName
                                <input type="hidden" name="Items[@i].ProductId" value="@line.ProductId" />
                            </td>
                            <td class="text-end">@line.SoldQuantity.ToString("N2")</td>
                            <td class="text-end">@line.ReturnedQuantity.ToString("N2")</td>
                            <td class="text-end">@line.MaxQuantity.ToString("N2")</td>
                            <td>
                                <input name="Items[@i].Quantity" class="form-control" type="number" min="0" max="@line.MaxQuantity" step="0.01" value="@line.Quantity" @(disabled || line.MaxQuantity <= 0 ? "readonly" : "") />
                            </td>
                            <td>
                                <input name="Items[@i].DamagedQuantity" class="form-control" type="number" min="0" max="@line.MaxQuantity" step="0.01" value="@line.DamagedQuantity" @(disabled || line.MaxQuantity <= 0 ? "readonly" : "") />
                            </td>
                            <td>
                                <input name="Items[@i].Notes" class="form-control" value="@line.Notes" @(disabled || line.MaxQuantity <= 0 ? "readonly" : "") />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <h5>Outside Sales Damage Return</h5>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered" id="outsideDamageTable">
                    <thead>
                        <tr>
                            <th style="width:22%">Category</th>
                            <th style="width:34%">Product</th>
                            <th style="width:170px">Damage Quantity</th>
                            <th>Note</th>
                            <th style="width:90px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="outside-row template d-none">
                            <td>
                                <select class="form-select category-select" disabled>
                                    <option value="">-- all categories --</option>
                                    @foreach (var category in Model.ProductCategoryList)
                                    {
                                        <option value="@category.Value">@category.Text</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <select name="OutsideItems[0].ProductId" class="form-select product-select" disabled>
                                    <option value="">-- select --</option>
                                    @foreach (var p in Model.ProductsFull)
                                    {
                                        <option value="@p.Id" data-category="@CategoryValue(p.ProductCategoryId)">@p.Name</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <input name="OutsideItems[0].DamagedQuantity" class="form-control" type="number" min="0" step="0.01" value="0" disabled />
                            </td>
                            <td>
                                <input name="OutsideItems[0].Notes" class="form-control" disabled />
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-danger remove-outside-row">Remove</button>
                            </td>
                        </tr>

                        @for (var i = 0; i < Model.OutsideItems.Count; i++)
                        {
                            var selectedProduct = Model.ProductsFull.FirstOrDefault(p => p.Id == Model.OutsideItems[i].ProductId);
                            var disabled = Model.Return.Status == "Processed";
                            <tr class="outside-row">
                                <td>
                                    <select class="form-select category-select" disabled="@(disabled ? "disabled" : null)">
                                        <option value="">-- all categories --</option>
                                        @foreach (var category in Model.ProductCategoryList)
                                        {
                                            if (category.Value == selectedProduct?.ProductCategoryId?.ToString())
                                            {
                                                <option value="@category.Value" selected>@category.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@category.Value">@category.Text</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="OutsideItems[@i].ProductId" class="form-select product-select" disabled="@(disabled ? "disabled" : null)">
                                        <option value="">-- select --</option>
                                        @foreach (var p in Model.ProductsFull)
                                        {
                                            if (p.Id == Model.OutsideItems[i].ProductId)
                                            {
                                                <option value="@p.Id" data-category="@CategoryValue(p.ProductCategoryId)" selected>@p.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@p.Id" data-category="@CategoryValue(p.ProductCategoryId)">@p.Name</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input name="OutsideItems[@i].DamagedQuantity" class="form-control" type="number" min="0" step="0.01" value="@Model.OutsideItems[i].DamagedQuantity" @(disabled ? "readonly" : "") />
                                </td>
                                <td>
                                    <input name="OutsideItems[@i].Notes" class="form-control" value="@Model.OutsideItems[i].Notes" @(disabled ? "readonly" : "") />
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-danger remove-outside-row" disabled="@(disabled ? "disabled" : null)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.Return.Status != "Processed")
            {
                <div class="mb-3">
                    <button id="addOutsideDamage" type="button" class="btn btn-secondary">Add Outside Damage</button>
                </div>
            }
        }

        <div class="mb-3">
            <label asp-for="Return.Reason" class="form-label"></label>
            <textarea asp-for="Return.Reason" class="form-control" readonly="@(Model.Return.Status == "Processed" ? "readonly" : null)"></textarea>
        </div>

        <div class="d-flex gap-2">
            @if (Model.Return.Status != "Processed")
            {
                <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Save</button>
            }
            <a asp-page="Details" asp-route-id="@Model.Return.Id" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('salesOrderSelect')?.addEventListener('change', function () {
            var value = this.value;
            var url = value ? '@Url.Page("Edit", new { id = Model.Return.Id })' + '?salesOrderId=' + encodeURIComponent(value) : '@Url.Page("Edit", new { id = Model.Return.Id })';
            window.location.href = url;
        });

        (function () {
            var table = document.getElementById('outsideDamageTable');
            if (!table) return;

            var tbody = table.querySelector('tbody');
            var template = tbody.querySelector('.template');
            var addButton = document.getElementById('addOutsideDamage');
            var productOptions = Array.prototype.map.call(template.querySelector('.product-select').options, function (option) {
                return {
                    value: option.value,
                    text: option.text,
                    category: normalize(option.dataset.category)
                };
            });

            addButton?.addEventListener('click', function () {
                var row = template.cloneNode(true);
                row.classList.remove('template', 'd-none');
                row.querySelectorAll('input, select, button').forEach(function (input) {
                    input.disabled = false;
                });
                tbody.appendChild(row);
                filterProducts(row, false);
                updateIndexes();
                bindRemoveButtons();
            });

            tbody.addEventListener('change', function (event) {
                var row = event.target.closest('tr');
                if (!row || row.classList.contains('template')) return;

                if (event.target.matches('.category-select')) {
                    filterProducts(row, true);
                }
            });

            function filterProducts(row, resetProduct) {
                var categorySelect = row.querySelector('.category-select');
                var productSelect = row.querySelector('.product-select');
                var selectedCategory = normalize(categorySelect.value);
                var currentValue = resetProduct ? '' : productSelect.value;

                productSelect.innerHTML = '';
                productOptions.forEach(function (source) {
                    if (source.value && selectedCategory && source.category !== selectedCategory) return;

                    var option = document.createElement('option');
                    option.value = source.value;
                    option.text = source.text;
                    option.dataset.category = source.category;
                    productSelect.appendChild(option);
                });

                if (currentValue && Array.prototype.some.call(productSelect.options, function (option) { return option.value === currentValue; })) {
                    productSelect.value = currentValue;
                }
            }

            function updateIndexes() {
                tbody.querySelectorAll('tr:not(.template)').forEach(function (row, index) {
                    row.querySelectorAll('input, select').forEach(function (input) {
                        if (input.name) {
                            input.name = input.name.replace(/OutsideItems\[\d+\]/, 'OutsideItems[' + index + ']');
                        }
                    });
                });
            }

            function bindRemoveButtons() {
                tbody.querySelectorAll('.remove-outside-row').forEach(function (button) {
                    button.onclick = function () {
                        button.closest('tr').remove();
                        updateIndexes();
                    };
                });
            }

            function normalize(value) {
                return (value || '').toString().trim().toLowerCase();
            }

            tbody.querySelectorAll('tr:not(.template)').forEach(function (row) {
                filterProducts(row, false);
            });
            bindRemoveButtons();
        })();
    </script>
}
