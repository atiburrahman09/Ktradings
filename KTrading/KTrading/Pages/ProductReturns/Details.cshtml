@page "{id:guid}"
@model KTrading.Pages.ProductReturns.DetailsModel
@{
    ViewData["Title"] = "Return Details";
}

<h2>Return Details</h2>

<div class="mb-3">
    <h4>Return #: @Model.Return?.ReturnNumber</h4>
    <p>Sales Order: @(Model.SalesOrderNumber ?? "-")</p>
    <p>Customer: @(Model.CustomerName ?? "-")</p>
    <p>Date: @Model.Return?.CreatedAt.ToString("yyyy-MM-dd")</p>
    <p>Status: @Model.Return?.Status</p>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Product</th>
            <th class="text-end">Return Quantity</th>
            <th class="text-end">Damage Quantity</th>
            <th class="text-end">Restock Quantity</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
    @foreach(var it in Model.Items ?? Enumerable.Empty<KTrading.Models.ProductReturnItem>())
    {
        <tr>
            <td>@(Model.ProductMap.ContainsKey(it.ProductId) ? Model.ProductMap[it.ProductId] : it.ProductId.ToString())</td>
            <td class="text-end">@it.Quantity.ToString("N2")</td>
            <td class="text-end">@KTrading.Pages.ProductReturns.DetailsModel.GetDamagedQuantity(it).ToString("N2")</td>
            <td class="text-end">@Math.Max(it.Quantity - KTrading.Pages.ProductReturns.DetailsModel.GetDamagedQuantity(it), 0m).ToString("N2")</td>
            <td>@it.Notes</td>
        </tr>
    }
    </tbody>
</table>

<div class="d-flex gap-2">
    <a asp-page="Index" class="btn btn-secondary">Back</a>

    @if (Model.Return?.Status != "Processed")
    {
        <a asp-page="Edit" asp-route-id="@Model.Return?.Id" class="btn btn-primary">Edit</a>
        <form method="post" asp-page-handler="Process" class="d-inline">
            <input type="hidden" name="id" value="@Model.Return?.Id" />
            <button type="submit" class="btn btn-warning" onclick="return confirm('Process this return and update stock?');">Process Return</button>
        </form>
    }
    else
    {
        <span class="badge bg-success align-self-center">Already Processed</span>
    }
</div>
