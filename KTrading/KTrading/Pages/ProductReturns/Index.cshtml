@page
@model KTrading.Pages.ProductReturns.IndexModel
@{
    ViewData["Title"] = "Product Returns";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Product Returns</h3>
        <a class="btn btn-primary" asp-page="Create">Create Return</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>Return#</th>
                    <th>Sales Order</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Returns)
            {
                <tr>
                    <td>@r.ReturnNumber</td>
                    <td>@(r.SalesOrderId == null ? "-" : (Model.SalesOrderMap.ContainsKey(r.SalesOrderId.Value) ? Model.SalesOrderMap[r.SalesOrderId.Value] : r.SalesOrderId.ToString()))</td>
                    <td>@(r.CustomerId == null ? "-" : (Model.CustomerMap.ContainsKey(r.CustomerId.Value) ? Model.CustomerMap[r.CustomerId.Value] : r.CustomerId.ToString()))</td>
                    <td>@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>@r.Status</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@r.Id"><i class="fas fa-eye"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <partial name="_Pagination" model="Model.Pager" />
    </div>
</div>
