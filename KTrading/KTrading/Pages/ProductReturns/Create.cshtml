@page
@model KTrading.Pages.ProductReturns.CreateModel
@{
    ViewData["Title"] = "Create Product Return";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-undo-alt"></i> Create Product Return</h3>
    </div>
    <form method="post" class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="Return.ReturnNumber" class="form-label"></label>
                <input asp-for="Return.ReturnNumber" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Return.SalesOrderId" class="form-label">Sales Order</label>
                <select asp-for="Return.SalesOrderId" asp-items="Model.SalesOrders" class="form-select" id="salesOrderSelect">
                    <option value="">-- select sales order --</option>
                </select>
                <span asp-validation-for="Return.SalesOrderId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Customer</label>
                <input class="form-control" value="@(Model.CustomerName ?? "-")" readonly />
            </div>
        </div>

        @if (Model.SelectedSalesOrder is not null)
        {
            <div class="mb-3">
                <div class="alert alert-info mb-0">
                    Return is based on sales order <strong>@Model.SelectedSalesOrder.OrderNumber</strong>.
                    Only products sold in this order can be returned.
                </div>
            </div>

            <h5>Sold Items</h5>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Sold</th>
                            <th class="text-end">Already Returned</th>
                            <th class="text-end">Returnable</th>
                            <th style="width:180px">Return Quantity</th>
                            <th style="width:120px">Damaged</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.ReturnLines.Count; i++)
                    {
                        var line = Model.ReturnLines[i];
                        <tr>
                            <td>
                                @line.ProductName
                                <input type="hidden" name="Items[@i].ProductId" value="@line.ProductId" />
                            </td>
                            <td class="text-end">@line.SoldQuantity.ToString("N2")</td>
                            <td class="text-end">@line.ReturnedQuantity.ToString("N2")</td>
                            <td class="text-end">@line.ReturnableQuantity.ToString("N2")</td>
                            <td>
                                <input name="Items[@i].Quantity" class="form-control" type="number" min="0" max="@line.ReturnableQuantity" step="0.01" value="0" @(line.ReturnableQuantity <= 0 ? "readonly" : "") />
                            </td>
                            <td class="text-center">
                                <input type="checkbox" name="Items[@i].IsDamaged" value="true" class="form-check-input" @(line.ReturnableQuantity <= 0 ? "disabled" : "") />
                                <input type="hidden" name="Items[@i].IsDamaged" value="false" />
                            </td>
                            <td>
                                <input name="Items[@i].Notes" class="form-control" @(line.ReturnableQuantity <= 0 ? "readonly" : "") />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-secondary">
                Select a sales order to load the products available for return.
            </div>
        }

        <div class="mb-3">
            <label asp-for="Return.Reason" class="form-label"></label>
            <textarea asp-for="Return.Reason" class="form-control"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success" @(Model.SelectedSalesOrder is null ? "disabled" : "")><i class="fas fa-check"></i> Create Return</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('salesOrderSelect')?.addEventListener('change', function () {
            var value = this.value;
            var url = value ? '@Url.Page("Create")' + '?SalesOrderId=' + encodeURIComponent(value) : '@Url.Page("Create")';
            window.location.href = url;
        });
    </script>
}
