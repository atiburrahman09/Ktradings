@page
@model KTrading.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Products</h3>
        <a class="btn btn-primary" asp-page="Create">Create New</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4">
                <select asp-for="CategoryId" asp-items="Model.CategoryList" class="form-select">
                    <option value="">-- All Categories --</option>
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-secondary"><i class="fas fa-filter"></i> Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary"><i class="fas fa-times"></i> Clear</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th>SKU</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Unit</th>
                        <th class="text-end">Price</th>
                        <th>Active</th>
                        <th style="width:120px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Products)
                    {
                        <tr>
                            <td>@p.SKU</td>
                            <td>@p.Name</td>
                            <td>@(p.ProductCategory?.Name ?? "Uncategorized")</td>
                            <td>@p.Unit</td>
                            <td class="text-end">@p.Price.ToString("N2")</td>
                            <td>@(p.IsActive ? "Yes" : "No")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@p.Id"><i
                                    class="fas fa-edit"></i></a>
                                    <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@p.Id"><i
                                        class="fas fa-trash"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
