@page "{id:guid}"
@model KTrading.Pages.SalesOrders.DetailsModel
@{
    ViewData["Title"] = "Sales Order Details";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-invoice-dollar"></i> Sales Order Details</h3>
    </div>
    <div class="card-body">
        <h4>Order #: @Model.Order?.OrderNumber</h4>
        <p>Customer: @(Model.Customer?.Name ?? Model.Order?.CustomerId.ToString())</p>
        <p>Sales Officer: @(Model.SalesOfficer?.Name ?? "-")</p>
        <p>Date: @Model.Order?.OrderDate.ToString("yyyy-MM-dd")</p>

        <div class="row mb-3">
            <div class="col-md-3"><strong>Total:</strong> @Model.Order?.Total.ToString("N2")</div>
            <div class="col-md-3"><strong>Paid:</strong> @Model.Order?.PaidAmount.ToString("N2")</div>
            <div class="col-md-3"><strong>Due:</strong> @Model.Order?.DueAmount.ToString("N2")</div>
            <div class="col-md-3"><strong>Net:</strong> @((Model.Order?.Total - Model.Order?.Commission - Model.Order?.Khajna)?.ToString("N2"))</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3"><strong>Commission:</strong> @Model.Order?.Commission.ToString("N2")</div>
            <div class="col-md-3"><strong>Khajna:</strong> @Model.Order?.Khajna.ToString("N2")</div>
        </div>

        <form method="post" asp-page-handler="UpdateKhajna" asp-route-id="@Model.Order?.Id" class="row g-2 align-items-end mb-4">
            <div class="col-md-3">
                <label asp-for="KhajnaAmount" class="form-label">Khajna After Delivery</label>
                <input asp-for="KhajnaAmount" class="form-control" min="0" step="0.01" />
                <span asp-validation-for="KhajnaAmount" class="text-danger"></span>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Khajna</button>
            </div>
        </form>

        @if ((Model.Order?.DueAmount ?? 0) > 0)
        {
            <form method="post" asp-page-handler="CollectDue" asp-route-id="@Model.Order?.Id" class="row g-2 align-items-end mb-4">
                <div class="col-md-3">
                    <label asp-for="CollectionAmount" class="form-label">Due Collection</label>
                    <input asp-for="CollectionAmount" class="form-control" min="0.01" max="@Model.Order?.DueAmount" step="0.01" />
                    <span asp-validation-for="CollectionAmount" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="PaymentMethodId" class="form-label">Payment Method</label>
                    <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethodList" class="form-select">
                        <option value="">-- select --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="CollectionReference" class="form-label">Reference</label>
                    <input asp-for="CollectionReference" class="form-control" />
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-success"><i class="fas fa-hand-holding-dollar"></i> Collect Due</button>
                </div>
            </form>
        }

        <form method="post" asp-page-handler="RecordDamage" asp-route-id="@Model.Order?.Id" class="row g-2 align-items-end mb-4">
            <div class="col-md-4">
                <label asp-for="DamageProductId" class="form-label">Damage Product</label>
                <select asp-for="DamageProductId" class="form-select">
                    <option value="">-- select --</option>
                    @foreach (var item in Model.Items)
                    {
                        <option value="@item.ProductId">@(Model.ProductNames.TryGetValue(item.ProductId, out var productName) ? productName : item.ProductId)</option>
                    }
                </select>
                <span asp-validation-for="DamageProductId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="DamageQuantity" class="form-label">Damage Qty</label>
                <input asp-for="DamageQuantity" class="form-control" min="0.01" step="0.01" />
                <span asp-validation-for="DamageQuantity" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DamageNote" class="form-label">Damage Note</label>
                <input asp-for="DamageNote" class="form-control" />
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-warning"><i class="fas fa-triangle-exclamation"></i> Record Damage</button>
            </div>
        </form>

        <h5>Items</h5>
        <div class="table-responsive mb-3">
            <table class="table table-sm table-bordered">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@(Model.ProductNames.TryGetValue(item.ProductId, out var productName) ? productName : item.ProductId)</td>
                        <td class="text-end">@item.Quantity.ToString("N2")</td>
                        <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                        <td class="text-end">@item.LineTotal.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <h5>Payments</h5>
        <div class="table-responsive mb-3">
            <table class="table table-sm table-bordered">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>@payment.PaymentDate.ToString("yyyy-MM-dd")</td>
                        <td>@(payment.PaymentMethodId.HasValue && Model.PaymentMethodNames.TryGetValue(payment.PaymentMethodId.Value, out var methodName) ? methodName : "")</td>
                        <td>@payment.Reference</td>
                        <td class="text-end">@payment.Amount.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
            <a asp-page="/ProductReturns/Create" asp-route-SalesOrderId="@Model.Order?.Id" class="btn btn-primary">
                <i class="fas fa-undo-alt"></i> Create Return
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
