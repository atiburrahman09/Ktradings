@page
@model KTrading.Pages.SalesOrders.IndexModel
@{
    ViewData["Title"] = "Sales Orders";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Sales Orders</h3>
        <a class="btn btn-primary" asp-page="Create">Create New</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>Order#</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th class="text-end">Total</th>
                    <th style="width:100px"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.Orders)
            {
                <tr>
                    <td>@o.OrderNumber</td>
                    <td>@o.CustomerId</td>
                    <td>@o.OrderDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@o.Total.ToString("N2")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@o.Id"><i class="fas fa-eye"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>