@page
@model KTrading.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@functions {
    private static string Money(decimal value) => value.ToString("N2");
    private static string Quantity(decimal value) => value.ToString("N2");
}

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text">Manage products</p>
                <a class="btn btn-light btn-sm" asp-page="/Products/Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Stock / Inventory</h5>
                <p class="card-text">Stock overview and product in</p>
                <a class="btn btn-light btn-sm" asp-page="/Stocks/Index">Open</a>
                <a class="btn btn-light btn-sm" asp-page="/Stocks/Create">Add Stock</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Sales Orders</h5>
                <p class="card-text">Create and view orders</p>
                <a class="btn btn-light btn-sm" asp-page="/SalesOrders/Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Returns</h5>
                <p class="card-text">Manage returns</p>
                <a class="btn btn-light btn-sm" asp-page="/ProductReturns/Index">Open</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card border-primary mb-3">
            <div class="card-body">
                <div class="text-muted small">Today's Sales</div>
                <h4 class="mb-1">@Money(Model.TotalSalesAmount)</h4>
                <div class="text-muted small">@Model.TodayOrderCount order(s)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success mb-3">
            <div class="card-body">
                <div class="text-muted small">Today's Returns</div>
                <h4 class="mb-1">@Money(Model.TotalReturnAmount)</h4>
                <div class="text-muted small">@Model.TodayReturnCount return(s)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger mb-3">
            <div class="card-body">
                <div class="text-muted small">Today's Damaged</div>
                <h4 class="mb-1">@Money(Model.TotalDamageAmount)</h4>
                <div class="text-muted small">Return and stock damage</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-dark mb-3">
            <div class="card-body">
                <div class="text-muted small">Net After Return/Damage</div>
                <h4 class="mb-1">@Money(Model.NetAfterReturnsAndDamage)</h4>
                <div class="text-muted small">Sales - returns - damaged</div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title mb-0">Today's Total Sale Category Wise</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.SalesByCategory.Any())
                    {
                        <tr><td colspan="3" class="text-muted">No sales today.</td></tr>
                    }
                    @foreach (var row in Model.SalesByCategory)
                    {
                        <tr>
                            <td>@row.Category</td>
                            <td class="text-end">@Quantity(row.Quantity)</td>
                            <td class="text-end">@Money(row.Amount)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title mb-0">Today's Total Return Product Category Wise</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.ReturnsByCategory.Any())
                    {
                        <tr><td colspan="3" class="text-muted">No returns today.</td></tr>
                    }
                    @foreach (var row in Model.ReturnsByCategory)
                    {
                        <tr>
                            <td>@row.Category</td>
                            <td class="text-end">@Quantity(row.Quantity)</td>
                            <td class="text-end">@Money(row.Amount)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title mb-0">Today's Total Damaged Category Wise</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.DamagesByCategory.Any())
                    {
                        <tr><td colspan="3" class="text-muted">No damaged products today.</td></tr>
                    }
                    @foreach (var row in Model.DamagesByCategory)
                    {
                        <tr>
                            <td>@row.Category</td>
                            <td class="text-end">@Quantity(row.Quantity)</td>
                            <td class="text-end">@Money(row.Amount)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
