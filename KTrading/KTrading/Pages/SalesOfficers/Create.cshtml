@page
@model KTrading.Pages.SalesOfficers.CreateModel
@{
    ViewData["Title"] = "Create Sales Officer";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Create Sales Officer</h3>
    </div>
    <form method="post" class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="row mb-3">
            <div class="col-md-3">
                <label asp-for="SalesOfficer.Code" class="form-label"></label>
                <input asp-for="SalesOfficer.Code" class="form-control" />
            </div>
            <div class="col-md-5">
                <label asp-for="SalesOfficer.Name" class="form-label"></label>
                <input asp-for="SalesOfficer.Name" class="form-control" />
                <span asp-validation-for="SalesOfficer.Name" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="SalesOfficer.Phone" class="form-label"></label>
                <input asp-for="SalesOfficer.Phone" class="form-control" />
            </div>
        </div>
        <div class="form-check mb-3">
            <input asp-for="SalesOfficer.IsActive" class="form-check-input" />
            <label asp-for="SalesOfficer.IsActive" class="form-check-label"></label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Create</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
