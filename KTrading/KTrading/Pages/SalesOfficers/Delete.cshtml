@page "{id:guid}"
@model KTrading.Pages.SalesOfficers.DeleteModel
@{
    ViewData["Title"] = "Delete Sales Officer";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Delete Sales Officer</h3>
    </div>
    <div class="card-body">
        <p>Delete or deactivate <strong>@Model.SalesOfficer?.Name</strong>?</p>
        <form method="post" class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
            <a asp-page="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </form>
    </div>
</div>
