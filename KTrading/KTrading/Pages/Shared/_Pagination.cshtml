@model KTrading.Models.PaginationModel

@if (Model.TotalPages > 1)
{
    string PageUrl(int page)
    {
        var query = ViewContext.HttpContext.Request.Query.ToDictionary(kvp => kvp.Key, kvp => kvp.Value.ToString());
        query["PageNumber"] = page.ToString();
        var parameters = query.Select(kvp => new KeyValuePair<string, string?>(kvp.Key, kvp.Value));
        return ViewContext.HttpContext.Request.Path + QueryString.Create(parameters);
    }

    <nav aria-label="Pagination" class="mt-3">
        <ul class="pagination mb-0">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPreviousPage ? PageUrl(Model.PageNumber - 1) : "#")">Previous</a>
            </li>
            @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
            {
                <li class="page-item @(pageIndex == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@PageUrl(pageIndex)">@pageIndex</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNextPage ? PageUrl(Model.PageNumber + 1) : "#")">Next</a>
            </li>
        </ul>
    </nav>
}
