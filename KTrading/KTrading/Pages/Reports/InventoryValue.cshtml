@page
@model KTrading.Pages.Reports.InventoryValueModel
@{
    ViewData["Title"] = Model.ReportTitle;
}

<h2>@Model.ReportTitle Report</h2>

<div class="mb-3">
    <form method="get" class="row g-2 align-items-end">

        <div class="col-md-4">
            <label class="form-label">Product Category</label>
            <select asp-for="SelectedCategoryId"
                    asp-items="Model.CategoryList"
                    class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary">
                Filter
            </button>
        </div>

        <div class="col-auto">
            <a asp-page="ExportInventoryExcel"
               asp-route-categoryId="@Model.SelectedCategoryId"
               class="btn btn-success">
                Export Excel
            </a>
        </div>

    </form>
</div>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <a class="btn btn-primary" asp-page="ExportInventoryExcel">Export as Excel</a>
</div>

@if (!Model.Rows.Any())
{
    <div class="alert alert-warning">
        No inventory rows found for this report.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Category</th>
                <th>Product</th>
                <th class="text-end">Quantity</th>
                <th class="text-end">Unit Cost</th>
                <th class="text-end">Value</th>
            </tr>
        </thead>
        <tbody>
        @foreach(var r in Model.Rows)
        {
            <tr>
                <td>@r.Category</td>
                <td>@r.ProductName</td>
                <td class="text-end">@r.Quantity</td>
                <td class="text-end">@r.UnitCost.ToString("N2")</td>
                <td class="text-end">@r.Value.ToString("N2")</td>
            </tr>
        }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4">Total</th>
                <th class="text-end">@Model.TotalValue.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>
}
