@page
@model KTrading.Pages.Reports.InventoryValueModel
@{
    ViewData["Title"] = Model.ReportTitle;
}

<h2>@Model.ReportTitle Report</h2>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <a class="btn btn-outline-secondary" asp-page="InventoryValue">All Inventory</a>
    @foreach (var category in Model.BusinessCategories)
    {
        <a class="btn btn-outline-secondary" asp-page="InventoryValue" asp-route-categoryName="@category">@category Products</a>
    }
    <a class="btn btn-primary" asp-page="ExportInventoryExcel" asp-route-categoryName="@Model.CategoryName">Export as Excel</a>
</div>

@if (!Model.Rows.Any())
{
    <div class="alert alert-warning">
        No inventory rows found for this report.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Category</th>
                <th>Product</th>
                <th class="text-end">Quantity</th>
                <th class="text-end">Unit Cost</th>
                <th class="text-end">Value</th>
            </tr>
        </thead>
        <tbody>
        @foreach(var r in Model.Rows)
        {
            <tr>
                <td>@r.Category</td>
                <td>@r.ProductName</td>
                <td class="text-end">@r.Quantity</td>
                <td class="text-end">@r.UnitCost.ToString("N2")</td>
                <td class="text-end">@r.Value.ToString("N2")</td>
            </tr>
        }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4">Total</th>
                <th class="text-end">@Model.TotalValue.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>
}
