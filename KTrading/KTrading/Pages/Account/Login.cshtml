@page
@model KTrading.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="login-shell">
    <section class="login-hero">
        <div class="login-brandline">
            <div class="login-mark">
                <i class="fas fa-warehouse"></i>
            </div>
            <div>
                <strong>KTrading</strong>
                <span>Distribution Management</span>
            </div>
        </div>

        <div class="login-copy">
            <p class="eyebrow">Secure Workspace</p>
            <h1>Run sales, stock, and returns from one calm dashboard.</h1>
            <p>Monitor product flow, validate inventory before orders, and keep every movement traceable.</p>
        </div>

        <div class="login-highlights" aria-label="Application highlights">
            <div>
                <i class="fas fa-boxes-stacked"></i>
                <span>Live Stock</span>
            </div>
            <div>
                <i class="fas fa-file-invoice-dollar"></i>
                <span>Sales Orders</span>
            </div>
            <div>
                <i class="fas fa-chart-line"></i>
                <span>Reports</span>
            </div>
        </div>
    </section>

    <section class="login-card" aria-label="Sign in form">
        <div class="login-card-header">
            <p class="eyebrow">Account Access</p>
            <h2>Sign in</h2>
            <span>Use your KTrading account to continue.</span>
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email address</label>
                <div class="input-icon">
                    <i class="fas fa-envelope"></i>
                    <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" placeholder="name@company.com" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="current-password" />
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="form-check mb-0">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label"></label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="fas fa-right-to-bracket"></i> Sign in
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
